---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
}

const { title, eyebrow, description } = Astro.props;
---

<div class="flex flex-col gap-2">
  {eyebrow ? <p class="text-sm font-semibold uppercase tracking-wide text-muted">{eyebrow}</p> : null}
  <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">{title}</h2>
  {description ? <p class="max-w-3xl text-sm leading-6 text-muted">{description}</p> : null}
</div>
