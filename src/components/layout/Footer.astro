---
import type { CollectionEntry } from 'astro:content';
import { Link, Separator, Surface } from '@heroui/react';

interface Props {
  site: CollectionEntry<'site'>;
  navigation: CollectionEntry<'navigation'>;
}

const { site, navigation } = Astro.props;
const base = import.meta.env.BASE_URL;
const items = navigation.data.items.filter(item => {
  if (item.key === 'papers' && !site.data.showAcceptedPapers) {
    return false;
  }

  return true;
});

const toHref = (path: string) => {
  if (path === '/') {
    return `${base.replace(/\/$/, '')}/`;
  }

  return `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
};
---

<footer class="mx-auto mt-8 w-full max-w-6xl px-4 pb-6 sm:px-6 lg:px-8">
  <div class="flex flex-col gap-6">
    <div class="grid gap-6 md:grid-cols-3">
      <div class="space-y-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">TPM 2026</h2>
        <p class="text-sm leading-6 text-muted">
          {site.data.title}<br />
          {site.data.workshopDate}<br />
          {site.data.location}
        </p>
      </div>
      <div class="space-y-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">Navigation</h2>
        <div class="flex flex-col gap-2 text-sm">
          {items.map(item => <Link href={toHref(item.url)}>{item.title}</Link>)}
        </div>
      </div>
      <div class="space-y-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">Contact</h2>
        <div class="flex flex-col gap-2 text-sm text-muted">
          <Link href={`mailto:${site.data.contactEmail}`}>{site.data.contactEmail}</Link>
          <Link href={site.data.conferenceUrl} rel="noopener noreferrer" target="_blank">
            UAI 2026 website
            <Link.Icon />
          </Link>
        </div>
      </div>
    </div>
    <Separator />
  </div>
</footer>
