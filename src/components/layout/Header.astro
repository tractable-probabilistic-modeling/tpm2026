---
import type { CollectionEntry } from 'astro:content';
import { Link, Separator, Surface } from '@heroui/react';

interface Props {
  site: CollectionEntry<'site'>;
  navigation: CollectionEntry<'navigation'>;
  currentPath: string;
  compact?: boolean;
}

const { site, navigation, currentPath, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const items = navigation.data.items.filter(item => {
  if (item.key === 'papers' && !site.data.showAcceptedPapers) {
    return false;
  }

  return true;
});

const toHref = (path: string) => {
  if (path === '/') {
    return `${base.replace(/\/$/, '')}/`;
  }

  return `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
};
---

<header class="mx-auto w-full max-w-6xl px-4 pt-4 sm:px-6 lg:px-8">
  <div class="flex flex-col gap-4">
    {
      compact ? (
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <Link className="text-base font-semibold no-underline" href={toHref('/')}>TPM 2026</Link>
          <div class="flex flex-col gap-1 text-sm text-muted md:items-end">
            <span>Workshop at UAI 2026</span>
            <Link href={site.data.conferenceUrl} rel="noopener noreferrer" target="_blank">
              Conference website
              <Link.Icon />
            </Link>
          </div>
        </div>
      ) : (
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
          <div class="max-w-3xl">
            <Link className="text-base font-semibold no-underline" href={toHref('/')}>TPM 2026</Link>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
              {site.data.title}
            </h1>
            <p class="mt-2 text-lg text-muted">{site.data.subtitle}</p>
            <p class="mt-4 max-w-2xl text-sm leading-6 text-muted">
              {site.data.workshopDate} in {site.data.location}
            </p>
          </div>
          <div class="flex flex-col gap-1 text-sm text-muted md:items-end">
            <span>Workshop at UAI 2026</span>
            <Link href={site.data.conferenceUrl} rel="noopener noreferrer" target="_blank">
              Conference website
              <Link.Icon />
            </Link>
          </div>
        </div>
      )
    }
    <Separator />
    <nav aria-label="Primary navigation" class="flex flex-wrap gap-4 text-sm">
      {
        items.map(item => {
          const isActive = currentPath === item.url || (item.url === '/' && currentPath === '');

          return (
            <Link
              className={[
                'no-underline transition-opacity',
                isActive ? 'font-semibold text-foreground' : 'text-muted hover:text-foreground',
              ].join(' ')}
              href={toHref(item.url)}
            >
              {item.title}
            </Link>
          );
        })
      }
    </nav>
  </div>
</header>
