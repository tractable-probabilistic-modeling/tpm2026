---
import type { CollectionEntry } from 'astro:content';
import { Button, Link, Surface } from '@heroui/react';
import workshopImage from '../../assets/images/hero-workshop.jpg';

interface Props {
  site: CollectionEntry<'site'>;
  home: CollectionEntry<'pages'>;
}

const { site, home } = Astro.props;
const base = import.meta.env.BASE_URL;
const toHref = (path: string) => {
  if (path === '/') {
    return `${base.replace(/\/$/, '')}/`;
  }

  return `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
};
---

<div class="grid gap-0 lg:grid-cols-[1.2fr_0.8fr]">
  <div class="flex flex-col justify-between gap-6 py-6 sm:py-8">
    <div class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-muted">UAI 2026 Workshop</p>
      <h2 class="max-w-3xl text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        {site.data.title}
      </h2>
      <p class="text-xl text-muted">{site.data.subtitle}</p>
      <p class="max-w-2xl text-base leading-7 text-muted">{site.data.description}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <Button asChild>
        <a href={toHref('/cfp')}>Read the call for papers</a>
      </Button>
      <Button asChild variant="secondary">
        <a href={toHref('/program')}>View the tentative program</a>
      </Button>
    </div>
  </div>
  <div class="relative min-h-[280px] lg:min-h-full">
    <img
      alt="Canal view in Amsterdam"
      class="absolute inset-0 h-full w-full object-cover rounded-2xl mx-2"
      src={workshopImage.src}
    />
  </div>
</div>
