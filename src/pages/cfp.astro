---
import { Card } from '@heroui/react';
import { getCollection, render } from 'astro:content';

import DatesSection from '../components/sections/DatesSection.astro';
import Prose from '../components/ui/Prose.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const [siteEntry] = await getCollection('site');
const [navigationEntry] = await getCollection('navigation');
const [cfpPage] = await getCollection('pages', ({ id }) => id === 'cfp');
const { Content } = await render(cfpPage);
---

<BaseLayout
  description={cfpPage.data.description}
  navigationEntry={navigationEntry}
  siteEntry={siteEntry}
  title={`${cfpPage.data.title} | TPM 2026`}
>
  <section class="space-y-5">
    <SectionHeading
      eyebrow="TPM 2026"
      title={cfpPage.data.title}
      description={cfpPage.data.description}
    />
    <Card className="px-5 py-6 sm:px-6" variant="default">
      <Prose>
        <Content />
      </Prose>
    </Card>
  </section>

  <DatesSection site={siteEntry} />
</BaseLayout>
